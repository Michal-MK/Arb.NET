<Project>

  <!--
    Auto-include l10n.yaml (if present) and all .arb files as AdditionalFiles so the
    Roslyn source generator can see them without any changes to the consumer's .csproj.
  -->
  <ItemGroup>
    <AdditionalFiles Include="$(MSBuildProjectDirectory)\**\l10n.yaml" />
    <AdditionalFiles Include="$(MSBuildProjectDirectory)\**\*.arb" />
  </ItemGroup>

  <!--
    Make namespace-related project properties visible to the generator so it can
    mirror the same fallback precedence as the CLI/IDE path when output-namespace
    is not specified in l10n.yaml.
  -->
  <ItemGroup>
    <CompilerVisibleProperty Include="RootNamespace" />
    <CompilerVisibleProperty Include="AssemblyName" />
    <CompilerVisibleProperty Include="MSBuildProjectName" />
  </ItemGroup>

  <Target Name="ArbGenerateBootstrap"
          BeforeTargets="CoreCompile">
    <ItemGroup>
      <_ArbGeneratedFiles Include="$(MSBuildProjectDirectory)\**\*.g.cs" />
    </ItemGroup>
    <Exec Command="arb generate &quot;$(MSBuildProjectDirectory)&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)"
          ContinueOnError="true"
          IgnoreExitCode="true"
          Condition="'@(_ArbGeneratedFiles)' == ''" />
  </Target>
</Project>
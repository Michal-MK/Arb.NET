<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ext="using:ExampleFive.Extensions"
             x:Class="ExampleFive.MainPage"
             BackgroundColor="Black">
    <VerticalStackLayout Padding="30,0"
                         Spacing="25"
                         VerticalOptions="Center"
                         HorizontalOptions="Center">
        <Label Text="Raw String" FontSize="32" TextColor="White" />
        <Label Text="{ext:Arb AppTitle}" FontSize="32" TextColor="White" />
        <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
            <Button Text="EN" Clicked="OnEnClicked" />
            <Button Text="CS" Clicked="OnCsClicked" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
